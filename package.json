{
  "name": "doudizhu-webgame",
  "version": "1.1.3",
  "description": "斗地主网页版 - 支持人机对战、局域网联机、自定义模式",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"vite\"",
    "server": "node server/index.js",
    "server:dev": "node server/index.js --dev",
    "client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "npm run server",
    "test": "node test/core.test.mjs"
