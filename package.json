{
  "name": "doudizhu-webgame",
  "version": "1.2.18",
  "description": "斗地主网页版 - 支持人机对战、局域网联机、自定义模式",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"npm run server:dev\" \"vite\"",
    "server": "node server/index.js",
    "server:dev": "node server/index.js --dev",
    "lan:host": "npm run build && node server/index.js",
    "client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "npm run server",
    "test": "node test/core.test.mjs",
    "test:core": "node test/core.test.mjs",
    "test:daily": "node test/daily-challenge.test.mjs",
    "test:lan": "node test/run-lan-test.mjs",
    "test:ui": "node test/ui-browser.mjs",
    "test:all": "node test/core.test.mjs && node test/daily-challenge.test.mjs && node test/run-lan-test.mjs && node test/ui-browser.mjs"
  },
  "keywords": [
    "doudizhu",
    "poker",
    "webgame",
    "websocket"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.0",
    "playwright": "^1.60.0",
    "vite": "^6.4.2"
  },
  "dependencies": {
    "express": "^4.18.0",
    "ws": "^8.14.0"
  }
}
